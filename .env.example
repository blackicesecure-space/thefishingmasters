# ============================================================
# The Fishing Masters – Environment Variables
# ============================================================
# Kopiere diese Datei nach .env und fuege deine Werte ein:
#   cp .env.example .env
# ============================================================

# --- Supabase ---
# Erstelle ein Projekt auf https://supabase.com und kopiere die Werte
# aus Settings > API
SUPABASE_URL=https://dein-projekt.supabase.co
SUPABASE_ANON_KEY=eyJ...dein-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJ...dein-service-role-key

# --- ML Service ---
# URL des Python FastAPI ML-Service (Standard: localhost:8001)
ML_API_BASE_URL=http://127.0.0.1:8001

# --- GraphQL API ---
# Port fuer den Apollo Server (Standard: 4000)
PORT=4000

# --- OpenWeather API (Phase 2) ---
# Kostenloser API-Key von https://openweathermap.org/api
# OPENWEATHER_API_KEY=dein-api-key

# --- Mapbox (Phase 3 – Web-App) ---
# Kostenloser Token von https://www.mapbox.com/
# NEXT_PUBLIC_MAPBOX_TOKEN=pk.dein-mapbox-token
